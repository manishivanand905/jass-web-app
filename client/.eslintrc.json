{
  "extends": ["react-app", "react-app/jest"],
  "rules": {
    "react/prop-types": "off",
    "react/jsx-no-comment-textnodes": "off",
    "react/no-unescaped-entities": "off",
    "no-unused-vars": "warn",
    "react/jsx-key": "warn",
    "jsx-a11y/label-has-associated-control": "off",
    "no-case-declarations": "off",
    "no-empty": "warn"
  }
}
